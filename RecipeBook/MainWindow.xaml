<Window x:Class="RecipeBook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dd_recipes="clr-namespace:RecipeBook.DynamicDataApproach.Recipes"
        xmlns:dd_cart="clr-namespace:RecipeBook.DynamicDataApproach.Cart"
        xmlns:ev_recipes="clr-namespace:RecipeBook.EventsApproach.Recipes"
        xmlns:ev_cart="clr-namespace:RecipeBook.EventsApproach.Cart"
        Title="Recipe Book — MVVM Comparison"
        Height="680" Width="1100"
        MinHeight="500" MinWidth="800">
    <TabControl>
        <TabItem Header="DynamicData (Rx.NET)">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="350"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*" MinWidth="350"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#5DADE2" BorderThickness="2" Margin="4" CornerRadius="4">
                    <dd_recipes:RecipeBookView x:Name="DD_RecipeBookView"/>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

                <Border Grid.Column="2" BorderBrush="#52BE80" BorderThickness="2" Margin="4" CornerRadius="4">
                    <dd_cart:GroceryCartView x:Name="DD_GroceryCartView"/>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Events (ObservableCollection)">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="350"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*" MinWidth="350"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#5DADE2" BorderThickness="2" Margin="4" CornerRadius="4">
                    <ev_recipes:RecipeBookView x:Name="EV_RecipeBookView"/>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

                <Border Grid.Column="2" BorderBrush="#52BE80" BorderThickness="2" Margin="4" CornerRadius="4">
                    <ev_cart:GroceryCartView x:Name="EV_GroceryCartView"/>
                </Border>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
