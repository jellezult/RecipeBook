<UserControl x:Class="RecipeBook.EventsApproach.Recipes.RecipeBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:RecipeBook.EventsApproach.Recipes"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RecipeBookViewModel}"
             Background="#EBF5FC">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" MinWidth="160"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: Recipe list + add new recipe -->
        <DockPanel Grid.Column="0" LastChildFill="True" Background="#D6EAF8">
            <TextBlock DockPanel.Dock="Top"
                       Text="Recipes"
                       FontWeight="Bold" FontSize="15"
                       Margin="6,6,6,4"/>

            <!-- Recipe list + add row, scrolling together -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ListBox ItemsSource="{Binding Recipes}"
                             SelectedItem="{Binding SelectedRecipe}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:RecipeViewModel}">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Recipe.Name}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="2,0"/>

                                    <!-- Add to cart button -->
                                    <Button Grid.Column="1"
                                            Content="🛒"
                                            FontSize="14"
                                            ToolTip="Add to grocery cart"
                                            Command="{Binding DataContext.AddToCartCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>

                                    <!-- Remove recipe button -->
                                    <Button Grid.Column="2"
                                            Content="✕"
                                            Foreground="DarkRed"
                                            ToolTip="Remove recipe"
                                            Command="{Binding DataContext.RemoveRecipeCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Add recipe row directly below last item -->
                    <Border Padding="4" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding NewRecipeName, UpdateSourceTrigger=PropertyChanged}"
                                     Width="130" Height="28"/>
                            <Button Content="Add"
                                    Command="{Binding AddRecipeCommand}"
                                    Height="28"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#AED6F1"/>

        <!-- Right panel: Recipe detail (visible when a recipe is selected) -->
        <DockPanel Grid.Column="2" LastChildFill="True" Background="#D6EAF8"
                   Visibility="{Binding SelectedRecipe, Converter={StaticResource NullToVisibilityConverter}}">

            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding SelectedRecipe.Recipe.Name}"
                       FontWeight="Bold" FontSize="16"
                       Margin="8,8,8,4"/>

            <Separator DockPanel.Dock="Top" Margin="4,0"/>

            <TextBlock DockPanel.Dock="Top"
                       Text="Ingredients:"
                       FontWeight="SemiBold"
                       Margin="8,6,8,2"/>

            <!-- Ingredient list + add row, scrolling together -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ListBox ItemsSource="{Binding SelectedRecipe.Ingredients}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding}"
                                               VerticalAlignment="Center"
                                               Margin="2,0"/>

                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Foreground="DarkRed"
                                            ToolTip="Remove ingredient"
                                            Command="{Binding DataContext.SelectedRecipe.RemoveIngredientCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Add ingredient row directly below last item -->
                    <Border Padding="4" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding SelectedRecipe.AvailableIngredients}"
                                      SelectedItem="{Binding SelectedRecipe.SelectedIngredientToAdd}"
                                      Width="150" Height="28" Margin="0,0,4,0"/>
                            <Button Content="Add Ingredient"
                                    Command="{Binding SelectedRecipe.AddIngredientCommand}"
                                    Height="28"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Placeholder shown when no recipe is selected -->
        <TextBlock Grid.Column="2"
                   Text="Select a recipe to view its ingredients"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="Gray"
                   FontStyle="Italic"
                   Visibility="{Binding SelectedRecipe, Converter={StaticResource NullToVisibilityInverseConverter}}"/>
    </Grid>
</UserControl>
